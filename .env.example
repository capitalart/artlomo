# ========================
# 🌐 ENVIRONMENT SETTINGS (EXAMPLE)
# ========================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

ENVIRONMENT=prod
DEBUG=false
FLASK_ENV=production
FLASK_DEBUG=0

# Core Pathing
ARTLOMO_ROOT=/srv/artlomo/application
ARTLOMO_BASE_DIR=/srv/artlomo
ARTLOMO_FFMPEG_BIN=
ARTLOMO_FFPROBE_BIN=

# Lab Directories
LAB_UNPROCESSED_DIR=/srv/artlomo/storage/unprocessed
LAB_PROCESSED_DIR=/srv/artlomo/storage/processed
LAB_LOCKED_DIR=/srv/artlomo/storage/locked
ARTWORKS_INDEX_PATH=/srv/artlomo/storage/index.json
SKU_SEQUENCE_PATH=/srv/artlomo/storage/sku_sequence.txt

# ========================
# 🔐 SECRETS & CREDENTIALS
# ========================
# Generate fresh keys and replace these with your actual values

# --- OpenAI ---
OPENAI_API_KEY=sk-proj-your-api-key-here
OPENAI_PROJECT_ID=proj_your-project-id
OPENAI_ORG_ID=org-your-org-id
OPENAI_MODEL_STACK=gpt-5.2,gpt-5.1,gpt-5,gpt-4o

# --- Google Gemini ---
GEMINI_API_KEY=AIzaSyD_your-gemini-key-here
GEMINI_MODEL_STACK=gemini-3.1-flash,gemini-3-pro
MOCKUP_IMAGE_GENERATION_MODEL=gemini-3.1-flash-image-preview
MOCKUP_IMAGE_EDIT_MODEL=gemini-3-pro-image-preview

# --- Security ---
ADMIN_USERNAME=robbie
ADMIN_PASSWORD=your-secure-password-here
SECRET_KEY=your-random-secret-key-here
FLASK_SECRET_KEY=your-random-flask-secret-key-here
