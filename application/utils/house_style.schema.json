{
  "$id": "https://artlomo/schema/house_style.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HouseStyleConfig",
  "type": "object",
  "required": ["version", "etsyShopUrl", "allowedEmojis", "sections"],
  "properties": {
    "version": { "type": "string" },
    "etsyShopUrl": { "type": "string", "format": "uri" },
    "allowedEmojis": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "forbiddenUrlsRegex": { "type": "string" },
    "forbiddenEmailRegex": { "type": "string" },
    "forbiddenPhoneRegex": { "type": "string" },
    "etsyUrlLiteral": { "type": "string", "format": "uri" },
    "etsyUrlMustBeLiteral": { "type": "boolean" },
    "literalEtsyUrlRegex": { "type": "string" },
    "forbidMarkdownLinks": { "type": "boolean" },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["heading","emojiPolicy"],
        "properties": {
          "heading": { "type": "string" },
          "alias": { "type": "string" },
          "optional": { "type": "boolean" },
          "minWords": { "type": "integer", "minimum": 0 },
          "maxWords": { "type": "integer", "minimum": 0 },
          "minLines": { "type": "integer", "minimum": 0 },
          "minBullets": { "type": "integer", "minimum": 0 },
          "bulletStartsWith": { "type": "string" },
          "stepsRequired": { "type": "array", "items": { "type": "string" } },
          "faqRequired": { "type": "array", "items": { "type": "string" } },
          "mustMention": { "type": "array", "items": { "type": "string" } },
          "require": { "type": "array", "items": { "type": "string" } },
          "requireAny": { "type": "array", "items": { "type": "string" } },
          "requireSomeOf": { "type": "array", "items": { "type": "array", "items": { "type": "string" }, "minItems": 1 } },
          "numbers": { "type": "object", "properties": { "pixelWidth": { "type": "number" }, "pixelHeight": { "type": "number" }, "maxPrintInches": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 }, "sizes": { "type": "array", "items": { "type": "string" }, "minItems": 1 } } },
          "etsyLinkRequired": { "type": "boolean" },
          "optionalPhrase": { "type": "string" },
          "notes": { "type": "string" },
          "emojiPolicy": { "type": "object", "required": ["maxInSection"], "properties": { "maxInSection": { "type": "integer", "minimum": 0 }, "allowed": { "type": "array", "items": { "type": "string" } } } }
        }
      }
    }
  }
}
